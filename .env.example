# Cloudflare Tunnel token (required)
# Get this from: Cloudflare Zero Trust > Networks > Tunnels > Create tunnel
CLOUDFLARED_TOKEN=

# Optional overrides
# IMAGE_NAME=personalsite
# IMAGE_TAG=latest
# CONTAINER_NAME=personalsite
# APP_PORT=8000      # internal only — cloudflared connects to it inside the container
# GUNICORN_WORKERS=2
